{
  "name": "yandex-music-discord-rpc",
  "version": "1.5.0",
  "description": "Официальное приложение RPC для статуса в Discord",
  "author": "Yandex Music RPC",
  "main": "electron/main.js",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "app": "electron .",
    "postinstall": "node scripts/patch-discord-rpc.js && node scripts/ensure-icon.js",
    "icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-build-icon.ps1",
    "dist": "pnpm run icon && electron-builder --win --x64",
    "dist:nomsi": "pnpm run icon && electron-builder --win nsis portable --x64",
    "pack": "pnpm run icon && electron-builder --win --x64 --dir",
    "dev:rpc": "node index.js"
  },
  "dependencies": {
    "discord-rpc": "^3.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yandexmusic.discordrpc",
    "productName": "Yandex Music RPC",
    "copyright": "Copyright © Yandex Music RPC",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "scripts/**/*.ps1",
      "electron/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yandex Music RPC",
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "msi": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yandex Music RPC",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
